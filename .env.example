MCP_PORT=17432
MCP_PUBLIC_BASE_URL=https://media-mcp.example.box.ca
MCP_BEARER_TOKEN=change-me
# Persists OAuth access/refresh tokens so MCP clients keep working across restarts.
# Path is relative to the process working dir. Written with 0600 perms.
# OAUTH_STATE_PATH=.oauth_state.json

RADARR_URL=http://127.0.0.1:7878
RADARR_API_KEY=change-me
RADARR_DEFAULT_ROOT_FOLDER=/home/user/files/Movies
RADARR_DEFAULT_QUALITY_PROFILE_ID=check http://<your-radarr-url>/api/v3/qualityprofile?apikey=<your-api-key>
RADARR_DEFAULT_MIN_AVAILABILITY=released

SONARR_URL=http://127.0.0.1:8989
SONARR_API_KEY=change-me
SONARR_DEFAULT_ROOT_FOLDER=/home/user/files/TV
SONARR_DEFAULT_QUALITY_PROFILE_ID=1
SONARR_DEFAULT_SERIES_TYPE=standard

PLEX_URL=http://127.0.0.1:32400
PLEX_TOKEN=change-me
PLEX_VERIFY_TLS=true
PLEX_MOVIE_SECTION=Movies
PLEX_TV_SECTION=TV Shows

TAUTULLI_ENABLED=false
TAUTULLI_URL=http://127.0.0.1:8181
TAUTULLI_API_KEY=

# ---------------------------------------------------------------------------
# Chat interface (seedbox-chat)
# ---------------------------------------------------------------------------

CHAT_PORT=17433
# Local testing: http://localhost:17433  Production: your public HTTPS URL
CHAT_PUBLIC_BASE_URL=https://chat.example.com
CHAT_SESSION_SECRET=change-me-to-a-long-random-string
# How long a signed-in session cookie remains valid (default 90 days).
# CHAT_SESSION_TTL_DAYS=90
# Stable UUID that identifies this app to Plex — generate once with: python3 -c "import uuid; print(uuid.uuid4())"
CHAT_PLEX_CLIENT_ID=change-me-to-a-uuid

ANTHROPIC_API_KEY=sk-ant-change-me

# Optional: path to a plain-text file that overrides the default system prompt
# SYSTEM_PROMPT_PATH=
